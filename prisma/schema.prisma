// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  STUDENT
  FREELANCER
  RECRUITER
  COMPANY
  ADMIN
  SUPER_ADMIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
  REMOTE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW
  HIRED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum NotificationType {
  MESSAGE
  JOB
  APPLICATION
  SYSTEM
  PAYMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id                    String                 @id @default(cuid())
  fullName              String
  username              String                 @unique
  email                 String                 @unique
  emailVerified         DateTime?
  phone                 String?
  password              String?
  role                  UserRole               @default(STUDENT)
  avatar                String?                // URL to avatar image
  coverImage            String?                // URL to cover image
  bio                   String?                @db.Text
  headline              String?                // e.g., "Full Stack Developer at XYZ"
  location              String?                // e.g., "San Francisco, CA"
  country               String?
  city                  String?
  website               String?                // Personal website
  linkedIn              String?                // LinkedIn profile URL
  github                String?                // GitHub profile URL
  behance               String?                // Behance profile URL
  dribbble              String?                // Dribbble profile URL
  twitter               String?                // Twitter/X profile URL
  instagram             String?                // Instagram profile URL
  youtube               String?                // YouTube profile URL
  isVerified            Boolean                @default(false)
  status                String                 @default("active") // active, suspended, banned
  profileCompletion     Int                    @default(0) // 0-100
  preferences           Json?                  // User preferences (notifications, privacy, etc.)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?

  // Relations
  accounts              Account[]
  sessions              Session[]
  verificationTokens    VerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  portfolio             Portfolio?
  resumes               Resume[]
  applications          Application[]
  jobsApplied           Job[]                  @relation("UserApplications")
  savedJobs             Job[]                  @relation("SavedJobs")
  projects              Project[]
  certificates          Certificate[]
  achievements          Achievement[]
  socialLinks           SocialLink[]
  skills                UserSkill[]
  experience            Experience[]
  education             Education[]
  messages              Message[]              @relation("MessageSender")
  receivedMessages      Message[]              @relation("MessageReceiver")
  conversations         Conversation[]         @relation("ConversationParticipants")
  notifications         Notification[]
  subscription          Subscription?
  payments              Payment[]
  reviews               Review[]               @relation("ReviewAuthor")
  receivedReviews       Review[]               @relation("ReviewRecipient")
  company               Company?               @relation("CompanyOwner")
  companiesFollowing    Company[]              @relation("CompanyFollowers")
  galleryItems          GalleryItem[]
  auditLogs             AuditLog[]
  mediaFiles            Media[]
  applicants            Application[]          @relation("ApplicantToRecruiter")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([userId])
}

// ============================================================================
// COMPANY & RECRUITER
// ============================================================================

model Company {
  id              String              @id @default(cuid())
  ownerId         String              @unique
  name            String
  slug            String              @unique
  logo            String?             // URL to logo
  cover           String?             // URL to cover image
  industry        String?             // e.g., "Technology", "Finance"
  website         String?
  email           String?
  phone           String?
  description     String?             @db.Text
  companySize     String?             // e.g., "1-50", "51-200", etc.
  foundedYear     Int?
  address         String?
  country         String?
  city            String?
  verified        VerificationStatus  @default(UNVERIFIED)
  verificationNotes String?
  followerCount   Int                 @default(0)
  reviewCount     Int                 @default(0)
  rating          Float?              @default(0)
  socialLinks     Json?               // Store social links as JSON
  culture         String?             @db.Text
  benefits        String?             @db.Text
  policies        Json?               // Store policies as JSON
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  // Relations
  owner           User                @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  jobs            Job[]
  applications    Application[]       @relation("CompanyApplications")
  projects        Project[]           @relation("CompanyProjects")
  reviews         Review[]            @relation("CompanyReviews")
  followers       User[]              @relation("CompanyFollowers")
  galleryItems    GalleryItem[]
  mediaFiles      Media[]             @relation("CompanyMedia")
  teamMembers     TeamMember[]
  subscription    CompanySubscription?
  payments        Payment[]           @relation("CompanyPayments")

  @@index([ownerId])
  @@index([verified])
}

model TeamMember {
  id        String   @id @default(cuid())
  companyId String
  email     String
  role      String   // "recruiter", "manager", etc.
  status    String   @default("pending") // pending, active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@index([companyId])
}

// ============================================================================
// JOBS
// ============================================================================

model Job {
  id                 String              @id @default(cuid())
  companyId          String
  title              String
  slug               String              @unique
  description        String              @db.Text
  shortDescription   String?
  salaryMin          Int?
  salaryMax          Int?
  salaryType         String?             @default("annual") // annual, monthly, hourly
  location           String?             // e.g., "San Francisco, CA"
  workMode           WorkMode            @default(ONSITE)
  employmentType     EmploymentType      @default(FULL_TIME)
  experience         String?             // e.g., "2-5 years"
  skills             String[]            // Array of skill names
  education          String?             // e.g., "Bachelor's"
  languages          String[]
  responsibilities   String?             @db.Text
  requirements       String?             @db.Text
  benefits           String?             @db.Text
  deadline           DateTime?
  openPositions      Int                 @default(1)
  status             String              @default("active") // active, closed, draft, paused
  featured           Boolean             @default(false)
  views              Int                 @default(0)
  applicantCount     Int                 @default(0)
  hiringProcess      String?             // e.g., "Screening > Interview > Offer"
  recruiterInfo      String?             // Recruiter name/contact
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  // Relations
  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications        Application[]       @relation("JobApplications")
  applicants          User[]              @relation("UserApplications")
  savedBy             User[]              @relation("SavedJobs")
  requiredSkills      JobSkillRequirement[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model JobSkillRequirement {
  id              String @id @default(cuid())
  jobId           String
  skillId         String
  proficiencyLevel String? // beginner, intermediate, advanced
  yearsRequired   Int?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@index([jobId])
  @@index([skillId])
}

model Application {
  id                String              @id @default(cuid())
  userId            String
  jobId             String
  companyId         String
  resumeId          String?
  coverLetter       String?             @db.Text
  portfolioLink     String?
  linkedInUrl       String?
  githubUrl         String?
  expectedSalary    Int?
  availability      String?             // e.g., "Immediate", "2 weeks"
  additionalInfo    Json?               // Store additional answers as JSON
  status            ApplicationStatus   @default(APPLIED)
  rating            Int?                // 1-5 rating from recruiter
  notes             String?             @db.Text
  rejectionReason   String?
  appliedAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  withdrawnAt       DateTime?

  // Relations
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  job               Job                 @relation("JobApplications", fields: [jobId], references: [id], onDelete: Cascade)
  company           Company             @relation("CompanyApplications", fields: [companyId], references: [id], onDelete: Cascade)
  resume            Resume?             @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  recruiter         User?               @relation("ApplicantToRecruiter")
  interview         Interview?
  timeline          ApplicationTimeline[]

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([companyId])
  @@index([status])
}

model ApplicationTimeline {
  id              String   @id @default(cuid())
  applicationId   String
  status          ApplicationStatus
  changedAt       DateTime @default(now())
  notes           String?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Interview {
  id                String   @id @default(cuid())
  applicationId     String   @unique
  type              String   // online, offline, phone, video
  scheduledAt       DateTime?
  duration          Int?     // in minutes
  meetingLink       String?
  interviewerName   String?
  interviewerEmail  String?
  location          String?  // For offline interviews
  feedbackForm      Json?    // Interview feedback as JSON
  result            String?  // pending, selected, rejected
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ============================================================================
// PORTFOLIO & RESUME
// ============================================================================

model Portfolio {
  id              String        @id @default(cuid())
  userId          String        @unique
  about           String?       @db.Text
  headline        String?
  theme           String        @default("light") // light, dark, minimal, corporate, creative, developer, designer
  primaryColor    String        @default("#2563EB")
  accentColor     String        @default("#06B6D4")
  fontFamily      String?       // e.g., "Poppins"
  backgroundStyle String?       // e.g., "gradient", "solid"
  customDomain    String?
  customCss       String?       @db.Text
  isPublished     Boolean       @default(false)
  viewCount       Int           @default(0)
  seoMetadata     Json?         // SEO title, description, keywords
  sectionOrder    String[]      // Order of sections: ["about", "skills", "experience", ...]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resume {
  id              String   @id @default(cuid())
  userId          String
  fileName        String
  fileUrl         String
  atsScore        Float?   // ATS compatibility score
  scoreDetails    Json?    // Detailed ATS score breakdown
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]

  @@index([userId])
}

// ============================================================================
// SKILLS & EXPERIENCE
// ============================================================================

model Skill {
  id              String   @id @default(cuid())
  name            String   @unique
  category        String?  // e.g., "Programming", "Design", "Business"
  description     String?
  endorsementCount Int     @default(0)
  createdAt       DateTime @default(now())

  // Relations
  userSkills      UserSkill[]
  jobRequirements JobSkillRequirement[]

  @@index([name])
  @@index([category])
}

model UserSkill {
  id              String   @id @default(cuid())
  userId          String
  skillId         String
  proficiencyLevel String   @default("intermediate") // beginner, intermediate, advanced, expert
  yearsOfExperience Int?
  endorsements    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill           Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
}

model Experience {
  id              String   @id @default(cuid())
  userId          String
  companyName     String
  position        String
  employmentType  EmploymentType
  startDate       DateTime
  endDate         DateTime?
  currentlyWorking Boolean @default(false)
  location        String?
  description     String?  @db.Text
  responsibilities String? @db.Text
  achievements    String?  @db.Text
  technologies    String[] // Array of tech stack
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
}

model Education {
  id              String   @id @default(cuid())
  userId          String
  school          String
  degree          String   // e.g., "Bachelor's"
  fieldOfStudy    String
  startYear       Int
  endYear         Int?
  currentlyStudying Boolean @default(false)
  cgpa            Float?
  description     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// PROJECTS & PORTFOLIO ITEMS
// ============================================================================

model Project {
  id              String   @id @default(cuid())
  userId          String?
  companyId       String?
  title           String
  slug            String   @unique
  description     String   @db.Text
  shortDescription String?
  images          String[] // Array of image URLs
  budget          Int?     // Budget in cents
  timeline        String?  // e.g., "2-4 weeks"
  technologies    String[] // Array of tech stack
  liveUrl         String?
  githubUrl       String?
  role            String?
  achievements    String?  @db.Text
  status          String   @default("open") // open, in-progress, completed, archived
  featured        Boolean  @default(false)
  views           Int      @default(0)
  applicantCount  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company? @relation("CompanyProjects", fields: [companyId], references: [id], onDelete: Cascade)
  applications    ProjectApplication[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

model ProjectApplication {
  id              String   @id @default(cuid())
  projectId       String
  userId          String
  coverLetter     String?  @db.Text
  portfolioLink   String?
  bidAmount       Int?     // Bid amount in cents
  deliveryDays    Int?
  status          String   @default("pending") // pending, accepted, rejected, completed
  appliedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String
  title           String
  issuer          String
  issueDate       DateTime
  expiryDate      DateTime?
  credentialId    String?
  credentialUrl   String?
  certificateUrl  String?  // URL to certificate image/PDF
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([issueDate])
}

model Achievement {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?  @db.Text
  achievedDate    DateTime
  category        String   // award, hackathon, competition, publication, patent
  url             String?  // Link to proof
  imageUrl        String?  // Achievement image
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model SocialLink {
  id              String   @id @default(cuid())
  userId          String
  platform        String   // linkedin, github, twitter, portfolio, etc.
  url             String
  displayName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

model GalleryItem {
  id              String   @id @default(cuid())
  userId          String?
  companyId       String?
  title           String?
  description     String?
  imageUrl        String
  type            String   @default("image") // image, video, document
  videoUrl        String?
  documentUrl     String?
  uploadedAt      DateTime @default(now())

  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

// ============================================================================
// MESSAGING & NOTIFICATIONS
// ============================================================================

model Conversation {
  id              String   @id @default(cuid())
  title           String?
  lastMessage     String?
  lastMessageAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  participants    User[]   @relation("ConversationParticipants")
  messages        Message[]

  @@index([updatedAt])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  receiverId      String?
  content         String   @db.Text
  attachmentUrl   String?
  attachmentType  String?  // image, pdf, document, etc.
  isRead          Boolean  @default(false)
  readAt          DateTime?
  deliveredAt     DateTime?
  replyToId       String?
  replyTo         Message? @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  reactions       Json?    // Store emoji reactions as JSON
  editedAt        DateTime?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User?    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  replies         Message[] @relation("MessageReply")

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  title           String
  message         String   @db.Text
  type            NotificationType
  relatedId       String?  // ID of related object (jobId, applicationId, etc.)
  relatedType     String?  // Type of related object
  isRead          Boolean  @default(false)
  readAt          DateTime?
  actionUrl       String?
  data            Json?    // Store additional data as JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================================================
// REVIEWS & RATINGS
// ============================================================================

model Review {
  id              String   @id @default(cuid())
  authorId        String
  companyId       String?
  recipientId     String?
  rating          Int      // 1-5
  title           String
  comment         String   @db.Text
  category        String?  // culture, salary, management, work-life-balance, etc.
  isVerified      Boolean  @default(false)
  helpful         Int      @default(0) // Number of helpful votes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  author          User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  company         Company? @relation("CompanyReviews", fields: [companyId], references: [id], onDelete: Cascade)
  recipient       User?    @relation("ReviewRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([companyId])
  @@index([recipientId])
}

// ============================================================================
// SUBSCRIPTION & PAYMENTS
// ============================================================================

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  plan            SubscriptionPlan @default(FREE)
  startDate       DateTime @default(now())
  endDate         DateTime?
  autoRenew       Boolean  @default(true)
  status          String   @default("active") // active, cancelled, expired
  cancelledAt     DateTime?
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[] @relation("SubscriptionPayments")

  @@index([plan])
  @@index([status])
}

model CompanySubscription {
  id              String   @id @default(cuid())
  companyId       String   @unique
  plan            SubscriptionPlan @default(FREE)
  startDate       DateTime @default(now())
  endDate         DateTime?
  autoRenew       Boolean  @default(true)
  status          String   @default("active") // active, cancelled, expired
  cancelledAt     DateTime?
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments        Payment[] @relation("CompanySubscriptionPayments")

  @@index([plan])
  @@index([status])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String?
  companyId       String?
  subscriptionId  String?
  companySubscriptionId String?
  amount          Int      // Amount in cents
  currency        String   @default("USD")
  status          PaymentStatus @default(PENDING)
  gateway         String   // stripe, razorpay, paypal, etc.
  transactionId   String?
  invoiceId       String?
  paymentMethod   String?
  metadata        Json?    // Store additional data
  refundedAmount  Int?     // Amount refunded in cents
  refundedAt      DateTime?
  failureReason   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company         Company? @relation("CompanyPayments", fields: [companyId], references: [id], onDelete: SetNull)
  subscription    Subscription? @relation("SubscriptionPayments", fields: [subscriptionId], references: [id], onDelete: SetNull)
  companySubscription CompanySubscription? @relation("CompanySubscriptionPayments", fields: [companySubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  userId          String?
  companyId       String?
  paymentId       String?
  subtotal        Int      // Amount in cents
  tax             Int      @default(0)
  total           Int
  currency        String   @default("USD")
  status          String   @default("issued") // issued, sent, viewed, paid
  dueDate         DateTime?
  paidAt          DateTime?
  items           Json     // Invoice line items
  notes           String?  @db.Text
  downloadUrl     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  type            String   // percentage, fixed
  value           Int      // Percentage or amount in cents
  maxUses         Int?
  usedCount       Int      @default(0)
  minAmount       Int?     // Minimum purchase amount in cents
  expiryDate      DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([active])
}

// ============================================================================
// ADMIN & MODERATION
// ============================================================================

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String   // create, update, delete, login, etc.
  resource        String   // User, Job, Company, etc.
  resourceId      String
  changes         Json?    // Track what changed
  ipAddress       String?
  userAgent       String?
  status          String   @default("success") // success, failure
  errorMessage    String?
  createdAt       DateTime @default(now())

  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model Report {
  id              String   @id @default(cuid())
  reporterId      String
  reportedUserId  String?
  reportedJobId   String?
  reportedCompanyId String?
  reason          String   // spam, abuse, inappropriate, copyright, etc.
  description     String   @db.Text
  attachmentUrl   String?
  status          String   @default("pending") // pending, investigating, resolved, dismissed
  resolution      String?  @db.Text
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([reason])
  @@index([createdAt])
}

model SystemSetting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String   @db.Text
  type            String   // string, number, boolean, json
  category        String?  // email, payment, security, etc.
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// MEDIA FILES
// ============================================================================

model Media {
  id              String   @id @default(cuid())
  userId          String?
  companyId       String?
  fileName        String
  originalName    String
  mimeType        String
  size            Int      // File size in bytes
  storageProvider String   @default("local") // local, s3, cloudinary, etc.
  storageKey      String   // Unique identifier in storage
  url             String
  thumbnailUrl    String?
  width           Int?     // For images
  height          Int?     // For images
  duration        Int?     // For videos in seconds
  folder          String   @default("general")
  isPublic        Boolean  @default(false)
  metadata        Json?    // Store additional metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company? @relation("CompanyMedia", fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}
